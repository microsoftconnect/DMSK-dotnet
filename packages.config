<?xml version="1.0" encoding="utf-8"?>
<!--
  This file declares third-party dependencies for GitHub Dependency Graph /
  Component Governance scanning. It is placed at the repository root so that
  GitHub can detect and monitor these packages for security vulnerabilities.

  NOTE: This file is NOT consumed by any MSBuild project in this repository.
  The actual runtime DLLs are vendored in x64/bin and x86/bin as part of
  the Nuance SpeechAnywhere SDK distribution.
-->
<packages>
  <package id="Azure.Core" version="1.44.1" targetFramework="net48" />
  <package id="log4net" version="3.3.0" targetFramework="net48" />
